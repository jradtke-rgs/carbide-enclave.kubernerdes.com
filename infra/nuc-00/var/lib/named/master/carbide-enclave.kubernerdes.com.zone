; Forward zone — carbide-enclave.kubernerdes.com
; Bump serial (YYYYMMDDNN) after any change and reload: rndc reload

$TTL 3600
@   IN SOA  nuc-00.carbide-enclave.kubernerdes.com. hostmaster.carbide-enclave.kubernerdes.com. (
                2026060903  ; Serial
                3600        ; Refresh
                900         ; Retry
                604800      ; Expire
                300 )       ; Negative TTL

    IN NS   nuc-00.carbide-enclave.kubernerdes.com.

; ── Infrastructure hosts ─────────────────────────────────────────────────────
nuc-00          IN A    10.0.0.10       ; Bastion / admin (this host)
ca              IN CNAME nuc-00         ; step-ca internal CA (port 8443)
hauler          IN CNAME nuc-00         ; Hauler registry (port 5000) + fileserver
nas             IN A    10.0.0.11       ; NAS / NFS

nuc-01          IN A    10.0.0.101      ; Harvester node 1
nuc-01-kvm      IN A    10.0.0.111      ; nuc-01 IP-KVM
nuc-02          IN A    10.0.0.102      ; Harvester node 2
nuc-02-kvm      IN A    10.0.0.112      ; nuc-02 IP-KVM
nuc-03          IN A    10.0.0.103      ; Harvester node 3
nuc-03-kvm      IN A    10.0.0.113      ; nuc-03 IP-KVM

spark           IN A    10.0.0.251      ; NVIDIA DGX Spark (arm64)

; ── RKE2 management cluster VMs ──────────────────────────────────────────────
rancher-01      IN A    10.0.0.31       ; RKE2 server VM 1
rancher-02      IN A    10.0.0.32       ; RKE2 server VM 2
rancher-03      IN A    10.0.0.33       ; RKE2 server VM 3

; ── Service VIPs ─────────────────────────────────────────────────────────────
harvester       IN A    10.0.0.100      ; Harvester VIP (set when cluster forms)
rancher         IN A    10.0.0.30       ; Rancher Manager + RKE2 API VIP (shared, no port conflict)
rke2            IN CNAME rancher        ; RKE2 API server alias (port 6443)
harbor          IN A    10.0.0.99       ; Harbor registry VIP
keycloak        IN A    10.0.0.98       ; Keycloak OIDC VIP

; ── Wildcard for Harbor project namespaces ───────────────────────────────────
; Allows harbor.carbide-enclave.kubernerdes.com and any subdomain
*.harbor        IN A    10.0.0.99
