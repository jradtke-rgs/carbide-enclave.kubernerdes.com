kubeconfig     = "~/.kube/carbide-enclave-harvester.kubeconfig"
namespace      = "vms-rancher"
ip_prefix      = "10.0.0"
network_name   = "mgmt"               # Harvester built-in mgmt network (single NIC setup)
ssh_public_key = "ssh-ed25519 AAAA... mansible@nuc-00"
admin_user     = "mansible"
vm_cpu         = 4
vm_memory      = "8Gi"
vm_disk_size   = "50Gi"
