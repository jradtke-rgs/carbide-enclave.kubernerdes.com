#!/usr/bin/env bash
# RGS enclave credentials — machine-local, NEVER committed to git
#
# Setup:
#   install -d -m 700 ~/.config/RGS
#   cp scripts/env.d/creds.example ~/.config/RGS/creds
#   chmod 600 ~/.config/RGS/creds
#   # fill in real values below
#
# This file documents every credential variable expected by the enclave
# scripts. ~/.bashrc.d/RGS sources this file and derives non-secret vars
# from it (token_id, token_password, HAULER_SOURCE_REPO_URL).

# ── SUSE Manager Tool ────────────────────────────────────────────────────────
export SMT_USER="smt_username"
export SMT_PASSWORD="NotAPassword"

# ── RGS Carbide registry ─────────────────────────────────────────────────────
export CARBIDE_USERNAME="carbide-user"
export CARBIDE_PASSWORD="NotAPassword"

# ── Docker Hub ───────────────────────────────────────────────────────────────
# Required to avoid anonymous pull rate limits (e.g. goharbor/* images)
# Use a personal access token (read-only scope is sufficient)
export DOCKER_USERNAME="docker-hub-user"
export DOCKER_PASSWORD="NotAPassword"

# ── step-ca ──────────────────────────────────────────────────────────────────
export STEP_CA_PASSWORD="NotAPassword"

# ── Harvester cluster ────────────────────────────────────────────────────────
export HARVESTER_TOKEN="NotAToken"          # cluster join token (all nodes must match)
export HARVESTER_PASSWORD="NotAPassword"    # OS root/rancher password on Harvester nodes

# ── RKE2 management cluster ───────────────────────────────────────────────────
export RKE2_TOKEN="NotAToken"               # shared secret for RKE2 node registration

# ── Harbor admin ─────────────────────────────────────────────────────────────
export HARBOR_ADMIN_PASSWORD="NotAPassword"
