# Terraform state and variable files
infra/tofu/**/*.tfstate
infra/tofu/**/*.tfstate.backup
infra/tofu/**/.terraform/
infra/tofu/**/.tofu/
infra/tofu/**/terraform.tfvars
!infra/tofu/**/terraform.tfvars.example

# Sensitive environment variables — non-sensitive values go in carbide-enclave.sh
scripts/env.d/*.secrets.sh
scripts/env.d/carbide-enclave.secrets.sh

# Kubeconfig and credential files
*.kubeconfig
kubeconfig
.kube/

# Hauler store (large binary artifact cache — not committed)
infra/hauler/store/

# Packer build artifacts
infra/packer/**/*.box
infra/packer/**/*.ova
infra/packer/**/*.qcow2
infra/packer/**/output-*/
infra/packer/**/.vagrant/

# Claude Code local settings (tool permissions — local artifact, not repo config)
.claude/settings.local.json

# macOS
.DS_Store
